rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
// Or paste into Firebase Console: Firestore Database -> Rules.

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user cellar backup. Each user's wines live at cellar/{uid}.
    // Only the authenticated owner can read or write their own document.
    match /cellar/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Blog posts. Reads are public (the client filters by moderationStatus).
    // Authenticated users may create posts attributed to themselves only,
    // and may delete only their own posts. No edits.
    match /blog_posts/{postId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() <= 2000;

      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      allow update: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
